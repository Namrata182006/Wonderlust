<% layout("/layouts/boilerplate.ejs") -%>
<body>
    <div class="row">
        <div class="card show-card col-9 offset-3 mt-5" style="width: 80vb;">
        <img src="<%= listing.image.url %>" class="card-img-top mb-3" alt="Listing_Image" style="height: 20rem;">
        <div class="card-body">
            <h5 class="card-title"><%= listing.title %></h5>
            <h6 class="card-price">&#8377; <%= listing.price.toLocaleString('en-IN') %></h6>
            <p>Owned by : <b><%= listing.owner.username %></b></p>
            <p class="card-text"><%= listing.description %></p>
            <h6 class="card-location">Location: <%= listing.location %></h6>
            <h6 class="card-location">Country: <%= listing.country %></h6>
            
            <div class="show-card-btn">
                <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
                <button class="btn btn-dark" style="background-color: #fe424d !important;"><a href="/listings/<%= listing._id %>/edit">Edit</a></button>
                <button class="btn btn-dark" ><a href="/listings/<%= listing._id %>/delete">Delete</a></button>
                <% } %>
            </div>

            <hr>
        </div>
    </div>

    
    <div class="col-8 offset-3 mt-5" style="width: 80vb;">
        
                <form action="/listings/<%= listing._id%>/review" method="post" novalidate class="needs-validation">
                    <h4>Leave a review</h4>
                    <div class="mb-3">
                         <fieldset class="starability-slot">
                            <legend> rating:</legend>
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                            <input type="radio" id="second-rate1" name="review[rating]" value="1" />
                            <label for="second-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="second-rate2" name="review[rating]" value="2" />
                            <label for="second-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="second-rate3" name="review[rating]" value="3" />
                            <label for="second-rate3" title="Average">3 stars</label>
                            <input type="radio" id="second-rate4" name="review[rating]" value="4" />
                            <label for="second-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="second-rate5" name="review[rating]" value="5" />
                            <label for="second-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>

                    <div class="mb-3" >
                        <label for="comment" class="form-label">comment</label>&nbsp;
                        <textarea name="review[comment]" id="comment" placeholder="Give your valuable comment here!" class="form-control" required></textarea>
                        <div class="invalid-feedback">Please enter valid Comment!</div>
                    </div>
                    <br>

                    <button class="btn btn-outline-dark mb-3">submit</button>

                </form>
                


                <h4>All Reviews</h4>
                <div class="row">
                    <% for(rev of listing.review) { %>
                <div class="review-card col-5 ms-3 mb-3" >
                    <div class="card-body">
                        <h5 class="card-title">@<%=rev.author.username%></h5>
                        <!-- <h6 class="card-subtitle mb-2 text-body-secondary"><%=rev.rating%>&#9734</h6> -->
                         <p class="starability-result card-text" data-rating="<%=rev.rating%>"> Rated: 3 stars</p>
                        <p class="card-text"><%=rev.comment%></p>


                        <% if(currUser._id.equals(rev.author._id)) { %>
                        <form action="/listings/<%=listing._id%>/review/<%=rev._id%>?_method=DELETE" method="Post" class="mb-3">
                            <button class="btn btn-outline-dark">Delete</button>
                        </form>
                        <% } %>
                        

                    </div>

                </div>
                <% } %>
                </div>

        </div>
    </div>


</body>



